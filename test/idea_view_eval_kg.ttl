@base <http://example.org/mock-kg/> .

@prefix kg:      <http://example.org/mock-kg/> .
@prefix mo:      <http://example.org/mock-ontology#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix schema:  <https://schema.org/> .

#################################################################
# Sample scholarly KG instantiated under the mock OWL ontology
#
# Technical variation checklist included in this file:
# - ontology/document IRI using <> and @base
# - prefixed IRIs, absolute IRIs, relative IRIs, and fragment IRIs
# - named individuals/classes from the imported ontology namespace
# - object-property assertions and data-property assertions
# - annotation assertions with language-tagged strings
# - typed literals: string, integer, decimal, boolean, date, dateTime, gYear
# - anonymous blank nodes [] and labeled blank nodes _:name
# - RDF collections/lists, RDF containers, RDF statement reification
# - OWL axiom annotation, owl:sameAs, owl:differentFrom, owl:AllDifferent
# - provenance with dcterms/prov/schema annotations
#################################################################

<> a owl:Ontology ;
    owl:imports <http://example.org/mock-ontology> ;
    owl:versionIRI <http://example.org/mock-kg/2026-05-26> ;
    rdfs:label "Sample scholarly KG using the mock ontology"@en ;
    rdfs:comment "A data graph demonstrating common RDF/OWL instantiation styles: relative IRIs, blank nodes, RDF lists, typed literals, reification, and provenance."@en ;
    dcterms:creator "Example KG Builder" ;
    dcterms:created "2026-05-26"^^xsd:date ;
    dcterms:source <https://example.org/source/mock-scholarly-corpus> ;
    owl:versionInfo "0.1.0" .

#################################################################
# Local helper properties used only to demonstrate KG structures
#################################################################

kg:orderedAuthors a rdf:Property ;
    rdfs:label "ordered authors"@en ;
    rdfs:comment "Demonstrates a Turtle RDF collection as an ordered list of author resources."@en .

kg:hasExtractionCandidate a rdf:Property ;
    rdfs:label "has extraction candidate"@en ;
    rdfs:comment "Connects a paper to a blank-node extraction candidate produced by a KGC system."@en .

kg:hasEvidence a rdf:Property ;
    rdfs:label "has evidence"@en .

kg:isOpenAccess a rdf:Property ;
    rdfs:label "is open access"@en .

#################################################################
# Main paper instance using a relative IRI subject
#################################################################

<paper/sudo-kg-2026>
    a mo:ConferencePaper, mo:EmpiricalPaper, mo:HighQualityPaper, mo:TwoAuthorPaper ;
    rdfs:label "SUDO-KG: Discourse-aware Scholarly Knowledge Graph Construction"@en ;
    skos:prefLabel "SUDO-KG"@en ;
    mo:title "SUDO-KG: Discourse-aware Scholarly Knowledge Graph Construction"^^xsd:string ;
    mo:doi "10.1234/sudo.kg.2026" ;
    mo:publicationYear "2026"^^xsd:gYear ;
    mo:citationCount 17 ;
    mo:qualityScore "0.93"^^xsd:decimal ;
    kg:isOpenAccess true ;
    schema:datePublished "2026-05-01"^^xsd:date ;
    prov:generatedAtTime "2026-05-26T09:30:00-04:00"^^xsd:dateTime ;
    schema:keywords "scholarly knowledge graph", "discourse modeling", "neuro-symbolic KGC" ;

    # Object-property assertions under the ontology
    mo:hasAuthor kg:alice_chen, <author/relative-bob>, _:anonymousConsortiumAuthor ;
    mo:hasPrimaryAuthor kg:alice_chen ;
    mo:usesDataset <dataset/openalex-subset>, _:heldOutDataset ;
    mo:usesBenchmarkDataset <https://semopenalex.org/resource/dataset/OpenAlex> ;
    mo:buildsOnMethod kg:graph_rag, <method/neuro-symbolic-filtering>, _:candidateExtractionMethod ;
    mo:publishedIn kg:ISWC2026 ;
    mo:cites <http://example.org/mock-kg/paper/absolute-iri-paper>, <paper/baseline-kg-construction> ;
    mo:canonicalRecordFor kg:paper_sudo_kg_canonical_record ;

    # Reflexive/self-style assertion matching the ontology's hasSelf example
    mo:relatedTo <paper/sudo-kg-2026> ;

    # Ordered author list using RDF collection shorthand
    kg:orderedAuthors ( kg:alice_chen <author/relative-bob> _:anonymousConsortiumAuthor ) ;

    # Annotation assertions on the instance
    mo:curatorNote "Main example paper. Demonstrates relative IRI subject, typed literals, repeated object values, and RDF list usage."@en ;
    mo:confidence "0.97"^^xsd:decimal ;

    # Nested anonymous blank node for extracted evidence
    kg:hasEvidence [
        a prov:Entity ;
        rdfs:label "Paragraph-level evidence span"@en ;
        rdf:value "The paper constructs a discourse-aware scholarly knowledge graph from full-text documents."@en ;
        dcterms:source <https://example.org/mock-paper/fulltext#paragraph-12> ;
        mo:confidence "0.89"^^xsd:decimal
    ] .

#################################################################
# Blank nodes: anonymous [] and labeled _:name
#################################################################

_:anonymousConsortiumAuthor
    a mo:Author ;
    rdfs:label "Anonymous consortium contributor"@en ;
    mo:emailAddress "consortium@example.org" .

_:heldOutDataset
    a mo:Dataset ;
    rdfs:label "Held-out paragraph annotation dataset"@en ;
    dcterms:identifier "local-bnode-dataset-001" ;
    dcterms:source <https://example.org/lab/internal-annotations.csv> .

_:candidateExtractionMethod
    a mo:Method ;
    rdfs:label "High-recall symbolic candidate extractor"@en ;
    rdfs:comment "A labeled blank node used where the method has no stable global IRI yet."@en ;
    dcterms:source <paper/sudo-kg-2026> .

# A blank node as the subject of a small provenance record.
[] a prov:Activity ;
   rdfs:label "Anonymous extraction activity"@en ;
   prov:used <paper/sudo-kg-2026> ;
   prov:wasAssociatedWith kg:curator_erin ;
   prov:endedAtTime "2026-05-26T09:45:00-04:00"^^xsd:dateTime .

#################################################################
# Authors: prefixed IRI, relative IRI, and fragment IRI subjects
#################################################################

kg:alice_chen
    a mo:Author ;
    rdfs:label "Alice Chen"@en ;
    skos:altLabel "A. Chen"@en ;
    mo:orcid "0000-0001-1111-1111" ;
    mo:emailAddress "alice.chen@example.org" ;
    mo:collaboratesWith <author/relative-bob> ;
    mo:mentors <#graduate-student-dan> .

<author/relative-bob>
    a mo:Author ;
    rdfs:label "Bob Rivera"@en ;
    mo:orcid "0000-0002-2222-2222" ;
    mo:contactEmail "bob.rivera@example.org" ;
    mo:authorOf <paper/sudo-kg-2026> .

<#graduate-student-dan>
    a mo:Author ;
    rdfs:label "Dan Local-Fragment"@en ;
    mo:orcid "0000-0003-3333-3333" .

kg:carol_mitra
    a mo:Author ;
    rdfs:label "Carol Mitra"@en ;
    mo:orcid "0000-0004-4444-4444" ;
    mo:reviews <paper/sudo-kg-2026> .

kg:curator_erin
    a prov:Agent ;
    rdfs:label "Erin Curator"@en ;
    schema:affiliation "Example Semantic Systems Lab" .

#################################################################
# Datasets, methods, tasks, venues
#################################################################

<dataset/openalex-subset>
    a mo:Dataset ;
    rdfs:label "OpenAlex scholarly metadata subset"@en ;
    dcterms:source <https://openalex.org/> ;
    schema:version "2026-04-snapshot" .

kg:graph_rag
    a mo:Method ;
    rdfs:label "Graph RAG"@en ;
    skos:definition "A retrieval-augmented generation method that retrieves over graph-structured context."@en .

<method/neuro-symbolic-filtering>
    a mo:Method ;
    rdfs:label "Neuro-symbolic filtering"@en ;
    rdfs:comment "Relative IRI method instance."@en .

<#scientific-question-answering>
    a mo:Task ;
    rdfs:label "Scientific question answering"@en .

kg:ISWC2026
    a mo:Venue ;
    rdfs:label "International Semantic Web Conference 2026"@en ;
    skos:prefLabel "ISWC 2026"@en .

#################################################################
# Additional papers demonstrating absolute IRIs, relative IRIs,
# sameAs, differentFrom, and ontology-enumerated individuals
#################################################################

<http://example.org/mock-kg/paper/absolute-iri-paper>
    a mo:Paper, mo:DatasetPaper ;
    rdfs:label "Absolute IRI baseline paper"@en ;
    mo:title "An Absolute-IRI Baseline for Scholarly KG Construction" ;
    mo:doi "10.1234/absolute.iri.paper" ;
    mo:publicationYear "2024"^^xsd:gYear ;
    mo:hasAuthor kg:carol_mitra ;
    mo:usesDataset <dataset/openalex-subset> .

<paper/baseline-kg-construction>
    a mo:Paper ;
    rdfs:label "Relative IRI baseline KG construction paper"@en ;
    mo:title "Earlier Work on KG Construction" ;
    mo:doi "10.1234/baseline.kg.2023" ;
    mo:publicationYear "2023"^^xsd:gYear ;
    mo:hasAuthor <author/relative-bob> .

kg:paper_sudo_kg_canonical_record
    a mo:Paper ;
    rdfs:label "Canonical record for SUDO-KG paper"@en ;
    owl:sameAs <paper/sudo-kg-2026>, <https://doi.org/10.1234/sudo.kg.2026> .

# Reuse ontology-defined named individuals from the imported ontology.
mo:paperA mo:cites <paper/sudo-kg-2026> .
mo:paperB mo:cites <paper/baseline-kg-construction> .

kg:alice_chen owl:differentFrom kg:carol_mitra .

[] a owl:AllDifferent ;
   owl:distinctMembers ( kg:alice_chen <author/relative-bob> kg:carol_mitra <#graduate-student-dan> ) .

#################################################################
# RDF container and RDF reification examples
#################################################################

kg:localReadingList
    a rdf:Seq ;
    rdfs:label "Example ordered reading list using rdf:Seq"@en ;
    rdf:_1 <paper/sudo-kg-2026> ;
    rdf:_2 <http://example.org/mock-kg/paper/absolute-iri-paper> ;
    rdf:_3 <paper/baseline-kg-construction> .

kg:citationAssertion1
    a rdf:Statement ;
    rdf:subject <paper/sudo-kg-2026> ;
    rdf:predicate mo:cites ;
    rdf:object <paper/baseline-kg-construction> ;
    mo:sourceSentence "The related work section explicitly compares against the earlier KG construction paper."@en ;
    mo:confidence "0.86"^^xsd:decimal ;
    prov:wasGeneratedBy kg:extraction_run_2026_05_26 .

# OWL axiom annotation for an asserted triple.
[] a owl:Axiom ;
   owl:annotatedSource <paper/sudo-kg-2026> ;
   owl:annotatedProperty mo:cites ;
   owl:annotatedTarget <paper/baseline-kg-construction> ;
   mo:sourceSentence "The related work section explicitly compares against the earlier KG construction paper."@en ;
   mo:confidence "0.86"^^xsd:decimal ;
   dcterms:source <https://example.org/mock-paper/fulltext#paragraph-7> .

#################################################################
# Extraction run provenance
#################################################################

kg:extraction_run_2026_05_26
    a prov:Activity ;
    rdfs:label "Mock KG extraction run"@en ;
    prov:startedAtTime "2026-05-26T09:00:00-04:00"^^xsd:dateTime ;
    prov:endedAtTime "2026-05-26T09:45:00-04:00"^^xsd:dateTime ;
    prov:wasAssociatedWith kg:curator_erin ;
    prov:used <https://example.org/source/mock-scholarly-corpus> .
