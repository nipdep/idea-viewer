sudo-kg-proposition:25b65817-a4de-44d5-b763-0e23c52578fd a sudo:Argument,
        sudo:Evidence ;
    rdfs:label "As a result, we construct a large-scale eventuality entailment graph (EEG), which has 10 million eventuality nodes and 103 million entailment edges."@en ;
    prov:derivedFrom "As a result, we construct a large-scale eventuality entailment graph (EEG), which has 10 million eventuality nodes and 103 million entailment edges."@en ;
    sudo:mentions sudo-kg-concept:890f0e67-e40e-46f6-869c-ee5bcad26408 ;
