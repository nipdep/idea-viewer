@prefix : <http://example.org/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Ontology
#################################################################

<http://example.org/ontology>
    a owl:Ontology .

#################################################################
# Classes
#################################################################

:Paper a owl:Class ;
    rdfs:label "Paper"@en . 

:influence a owl:DatatypeProperty ;
    rdfs:label "influence annotation"@en ;
    rdfs:range :InfluenceLevel .

:cites a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain :Paper ;
    rdfs:range :Paper ;
    rdfs:label "cites"@en .

:citedBy a owl:ObjectProperty ;
    owl:inverseOf :cites .

:InfluenceLevel
    a rdfs:Datatype ;
    rdfs:label "Influence Level"@en ;
    owl:equivalentClass [
        a rdfs:Datatype ;
        owl:onDatatype xsd:decimal ;
        owl:withRestrictions (
            [ xsd:minInclusive "0.0"^^xsd:decimal ]
            [ xsd:maxInclusive "1.0"^^xsd:decimal ]
        )
    ] .

:HighInfluencePaper
    a owl:Class ;
    rdfs:subClassOf :Paper ;
    rdfs:label "High Influence Paper"@en ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty :citedBy ;
        owl:someValuesFrom [
            a owl:Restriction ;
            owl:onProperty :influence ;
            owl:someValuesFrom [
                a rdfs:Datatype ;
                owl:onDatatype :InfluenceLevel ;
                owl:withRestrictions (
                    [ xsd:minInclusive "0.80"^^xsd:decimal ]
                    [ xsd:maxInclusive "1.00"^^xsd:decimal ]
                )
            ]
        ]
    ] .

#################################################################
# Individuals
#################################################################

:paperA a :Paper ;
    rdfs:label "Paper A"@en ;
    :cites :paperB ;
    :citationCount 42 .

:paperB a :Paper ;
    rdfs:label "Paper B"@en ;
    :citationCount 12 .

[] a owl:Axiom ;
   owl:annotatedSource :paperA ;
   owl:annotatedProperty :cites ;
   owl:annotatedTarget :paperB ;
   :sourceSentence "Paper A cites Paper B in the related work section."@en ;
   :infleunce "0.88"^^xsd:decimal .