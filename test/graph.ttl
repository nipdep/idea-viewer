sudo-kg-proposition:605876cc-b374-46f7-8416-0bb0f7a913b4 a sudo:Approach,
        sudo:Argument ;
    rdfs:label "In this paper, we propose a scalable approach to model the entailment relations between eventualities (\"eat an apple\" entails \"eat fruit."@en ;
    prov:derivedFrom "In this paper, we propose a scalable approach to model the entailment relations between eventualities (\"eat an apple\" entails \"eat fruit."@en ;
