{
  "name": "idea-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --strictPort",
    "dev:caddy": "vite --host 0.0.0.0 --strictPort --mode caddy",
    "dev:caddy:spark": "VITE_BASE_PATH=/idea-viewer/ VITE_DEV_ORIGIN=https://spark-6d47.tailb1f37b.ts.net VITE_HMR_PROTOCOL=wss VITE_HMR_HOST=spark-6d47.tailb1f37b.ts.net VITE_HMR_CLIENT_PORT=443 VITE_HMR_PATH=/idea-viewer/@vite/ws vite --host 0.0.0.0 --strictPort",
    "dev:caddy:spark:poll": "VITE_BASE_PATH=/idea-viewer/ VITE_DEV_ORIGIN=https://spark-6d47.tailb1f37b.ts.net VITE_HMR_PROTOCOL=wss VITE_HMR_HOST=spark-6d47.tailb1f37b.ts.net VITE_HMR_CLIENT_PORT=443 VITE_HMR_PATH=/idea-viewer/@vite/ws VITE_USE_POLLING=1 VITE_POLLING_INTERVAL=300 vite --host 0.0.0.0 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "test:projections": "node --import ./test/projection-helpers/register-node-loader.mjs --test test/view-projections.test.mjs",
    "test:projections:summary": "node --import ./test/projection-helpers/register-node-loader.mjs ./scripts/projection-test-manifest-summary.mjs",
    "test:projections:generate": "node --import ./test/projection-helpers/register-node-loader.mjs ./scripts/generate-projection-expectations.mjs"
  },
  "dependencies": {
    "@comunica/query-sparql": "^3.0.0",
    "@vercel/analytics": "^1.5.0",
    "cytoscape": "^3.30.0",
    "n3": "^1.20.0",
    "ngraph.forcelayout": "^3.3.1",
    "ngraph.graph": "^20.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^6.2.0"
  }
}
