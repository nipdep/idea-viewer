# Vite base path when proxied under a subpath in Caddy.
VITE_BASE_PATH=/idea-viewer/

# Public URL used by browser for dev assets/HMR.
# Update host/port to match your Caddy endpoint.
VITE_DEV_ORIGIN=http://localhost

# HMR settings for reverse proxy usage.
VITE_HMR_PROTOCOL=ws
VITE_HMR_HOST=localhost
VITE_HMR_CLIENT_PORT=80
VITE_HMR_PATH=/idea-viewer/@vite/ws
